{
    "position": "top",
    "margin-top": 10,
    "margin-bottom": 0,
    "margin-left": 15,
    "margin-right": 15,
    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "pulseaudio",
        "custom/bluetooth-battery",
        "network",
        "battery",
        "custom/notification"
    ],
    "clock": {
        "interval": 60,
        "format": "{:%H:%M}",
        "tooltip-format": "{:%d-%m-%Y}",
        "max-length": 25
    },
    "hyprland/workspaces": {
        "format": "{icon} | {windows}",
        "format-window-separator": "",
        "workspace-taskbar": {
            "enable": true,
            "update-active-window": true,
            "format": "{icon}",
            "icon-size": 18
        }
    },
