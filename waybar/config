{
    "position": "top",
    "margin-top": 10,
    "margin-bottom": 0,
    "margin-left": 15,
    "margin-right": 15,
    "spacing": 4,

    "modules-left": [
        "custom/arch",
        "hyprland/workspaces",
        "cpu",
        "memory"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "network#speed",
        "pulseaudio",
        "custom/bluetooth-battery",
        "network",
        "battery",
        "custom/notification"
    ],

    "clock": {
        "interval": 1,
        "format": "{:%H:%M:%S}",
        "format-alt": "{:%A, %d %B}",
        "tooltip-format": "{:%d-%m-%Y}",
        "max-length": 25
    },

    "custom/arch": {
        "format": "ïŒƒ",
        "tooltip": false,
        "on-click": "kitty -e sh -c 'fastfetch; read'"
    },

    "hyprland/workspaces": {
        "format": "{icon} | {windows}",
        "format-window-separator": "",
        "workspace-taskbar": {
            "enable": true,
            "update-active-window": true,
            "format": "{icon}",
            "icon-size": 18
        }
    },

    "cpu": {
        "interval": 2,
        "format": "َ°»  {usage}%",
        "tooltip-format": "CPU: {usage}%\nLoad: {load}",
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "memory": {
        "interval": 5,
        "format": "َ°چ› {percentage}%",
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "network#speed": {
        "interface": "wlan0",
        "format": "َ°پ† {bandwidthDownBytes}  َ°پ‍ {bandwidthUpBytes}",
        "format-disconnected": "",
        "interval": 2,
        "tooltip": false
    },
    
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "َ°‚° {volume}%",
        "format-muted": "َ°–پ",
        "format-icons": {
            "headphone": "َ°‹‹",
            "headset": "َ°‹ژ",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "scroll-step": 2,
        "on-click": "pavucontrol",
        "ignored-sinks": ["Easy Effects Sink"]
    },

    "network": {
        "interface": "wlan0",
        "format": "َ°¤­",
        "format-wifi": "َ°¤¨ {essid}",
        "format-ethernet": "َ°ٹ— {ipaddr}",
        "format-disconnected": "َ°¤­ off",
        "tooltip-format-wifi": "{essid}  {signalStrength}%\n{frequency} MHz",
        "tooltip-format-ethernet": "{ifname}  {ipaddr}",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 24
    },

    "battery": {
        "interval": 30,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "َ°‚„ {capacity}%",
        "format-plugged": "َ°ڑ¥ {capacity}%",
        "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
        "max-length": 25
    },

    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "َ±…«",
            "none": "َ°‚ڑ",
            "dnd-notification": "َ°‚ ",
            "dnd-none": "َ°ھ“",
            "inhibited-notification": "َ°‚›",
            "inhibited-none": "َ°ھ‘",
            "dnd-inhibited-notification": "َ°‚›",
            "dnd-inhibited-none": "َ°ھ‘"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    "custom/bluetooth-battery": {
        "exec": "~/.config/waybar/scripts/bt-battery.sh",
        "interval": 30,
        "tooltip": true,
        "format": "َ°‚° {}",
        "tooltip-format": "Bluetooth headset battery"
    }
}
